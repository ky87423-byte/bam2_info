generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum EventType {
  VIEW
  CALL
  MAP
  RESERVATION
}

enum UserRole {
  USER
  SHOP
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum PointAction {
  SIGNUP
  LOGIN
  ATTEND
  POST
  COMMENT
  LUCKY
  ADMIN
  ETC
}

enum InquiryStatus {
  NEW           // 신규 — 미확인
  REVIEWED      // admin 확인함
  FORWARDED     // admin이 업주에게 외부 연락 시도
  RESOLVED      // 처리 완료
}

enum ClaimStatus {
  PENDING       // 신청 대기
  APPROVED      // admin 승인 → Shop.ownerId 설정됨
  REJECTED      // admin 거절
}

enum MainLayout {
  GRID          // 그리드 (썸네일 카드 다열)
  LIST_CARD     // 리스트 카드 (가로형 한 줄당 한 업소)
  BOARD         // 게시판 (테이블형 — 제목 + 지역 + 카테고리 + 가격)
}

// ── Models ────────────────────────────────────────────────────────────────────

model Shop {
  id            Int      @id @default(autoincrement())
  company       String
  subject       String   @db.Text
  content       String   @db.Text
  area          String
  category      String   @default("")
  category2     String   @default("")
  phone         String   @default("")
  hphone        String   @default("")
  telegram      String   @default("")
  hit           Int      @default(0)
  price         Int      @default(0)
  mainPhoto     String   @default("")
  photos        String[]
  time1         String   @default("")
  time2         String   @default("")
  timeFull      Boolean  @default(false)
  isVisible     Boolean  @default(true)
  isScraped     Boolean  @default(true)   // 스크랩 출처 여부 (false = 회원이 직접 등록)
  externalId    Int?     @unique           // 외부 사이트 식별자 (wr_id) — 스마트 upsert 키
  lastScrapedAt DateTime?                   // 마지막 스크랩 동기화 시각
  virtualUserId Int?     @unique           // 자동 생성된 가상 User 계정 (1:1, lazy)
  ownerId       Int?                        // 클레임 승인 후 실 소유주 (real User)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastLoginAt   DateTime?

  owner           User?            @relation("ShopOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  analyticsEvents AnalyticsEvent[]
  inquiries       AdminInquiry[]
  claims          ClaimRequest[]

  @@index([lastLoginAt])                   // Retention: 미접속 업주 필터
  @@index([isScraped])                     // 스크랩 vs 회원 등록 구분 조회
  @@index([ownerId])                       // 특정 회원 소유 업소 조회
  @@index([lastScrapedAt])                 // sync: 오래된 데이터 우선 갱신
}

model AnalyticsEvent {
  id        Int       @id @default(autoincrement())
  storeId   Int
  eventType EventType
  ipAddress String
  createdAt DateTime  @default(now())

  shop Shop @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, eventType, createdAt]) // Sales Funnel: 업소+유형+기간
  @@index([createdAt, storeId])            // Popular Shops: 기간 필터 → storeId 집계
  @@index([ipAddress, createdAt])          // Suspicious IP: IP별 단시간 이벤트 감지
}

model SearchLog {
  id          Int      @id @default(autoincrement())
  keyword     String
  resultCount Int
  createdAt   DateTime @default(now())

  @@index([resultCount])                   // Demand-Supply: 결과 0건 키워드 필터
}

// ── User / PointLog (JSON 이관) ──────────────────────────────────────────────

model User {
  id             Int        @id @default(autoincrement())
  username       String     @unique
  nickname       String
  passwordHash   String     @default("")
  role           UserRole   @default(USER)
  status         UserStatus @default(ACTIVE)
  level          Int        @default(1)
  points         Int        @default(0)
  memo           String     @default("")
  shopPostLimit  Int?
  joinedAt       DateTime   @default(now())
  approvedAt     DateTime?
  blockedAt      DateTime?
  lastLoginDate  String?    @db.VarChar(10)   // YYYY-MM-DD
  lastAttendDate String?    @db.VarChar(10)
  attendStreak   Int        @default(0)
  totalAttend    Int        @default(0)

  isVirtual      Boolean    @default(false)   // 스크랩 업소를 위한 자동 생성 가상 계정
                                                // (passwordHash="", isVirtual=true → 로그인 불가)

  pointLogs        PointLog[]
  comments         Comment[]
  messagesSent     Message[]      @relation("MessagesSent")
  messagesReceived Message[]      @relation("MessagesReceived")
  shopsOwned       Shop[]         @relation("ShopOwner")
  inquiriesSent    AdminInquiry[] @relation("InquirySender")
  claimsRequested  ClaimRequest[] @relation("ClaimRequester")
  boardPosts       BoardPost[]    @relation("BoardPostAuthor")

  @@index([status])
  @@index([role])
  @@index([isVirtual])                          // /admin/users 등에서 빠른 필터링
}

model PointLog {
  id        Int         @id @default(autoincrement())
  userId    Int
  username  String       // 유저 탈퇴 후 로그 가독성 유지
  action    PointAction
  amount    Int          // + 지급, - 차감
  balance   Int          // 지급 직후 잔액 스냅샷
  memo      String      @default("")
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ── Comment (무한 확장형 polymorphic) ────────────────────────────────────────

model Comment {
  id          Int       @id @default(autoincrement())
  targetType  String    @db.VarChar(32)   // 'promotion' | 'free' | 'notice' | ...
  targetId    Int                            // 해당 게시판의 게시글 id
  authorId    Int
  parentId    Int?                           // null = top-level, not null = 답글
  content     String    @db.Text
  isLuckyWin  Boolean   @default(false)
  luckyAmount Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?                      // soft delete

  author  User      @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([targetType, targetId, createdAt])
  @@index([authorId, createdAt])
  @@index([parentId])
}

// ── Message (1:1 쪽지 시스템) ───────────────────────────────────────────────

model Message {
  id         Int      @id @default(autoincrement())
  content    String   @db.Text
  senderId   Int
  receiverId Int
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender   User @relation("MessagesSent",     fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId, isRead])         // 안 읽은 쪽지 카운트 (헤더 뱃지)
  @@index([receiverId, createdAt])      // 받은 쪽지함 최신순
  @@index([senderId,   createdAt])      // 보낸 쪽지함 최신순
  @@index([createdAt])                  // 관리자 전체 모니터링
}

// ── AdminInquiry — 가상 업소 수신 쪽지 우회 저장소 ─────────────────────────

model AdminInquiry {
  id            Int            @id @default(autoincrement())
  senderId      Int                                        // 보낸 (실제) 회원
  shopId        Int                                        // 어느 업소에 보낸 문의인지
  virtualUserId Int?                                       // 우회 시점의 가상 user (참고용)
  content       String         @db.Text
  status        InquiryStatus  @default(NEW)
  adminNote     String         @default("")                // admin 영업 결과 등 메모
  createdAt     DateTime       @default(now())
  reviewedAt    DateTime?

  sender User @relation("InquirySender", fields: [senderId], references: [id], onDelete: Cascade)
  shop   Shop @relation(fields: [shopId],   references: [id], onDelete: Cascade)

  @@index([status, createdAt])     // admin 화면: 신규 인콰이어리 우선
  @@index([shopId, createdAt])     // 특정 업소 인콰이어리 이력
  @@index([senderId, createdAt])   // 사용자 본인이 보낸 문의 내역
}

// ── ClaimRequest — 업소 소유권 주장 신청 ──────────────────────────────────

model ClaimRequest {
  id           Int          @id @default(autoincrement())
  shopId       Int                                          // 클레임 대상 업소
  claimantId   Int                                          // 신청자 (실 회원)
  status       ClaimStatus  @default(PENDING)
  proofText    String       @db.Text                        // 증빙 본문 (사업자번호·매장 사진 설명 등)
  contactPhone String       @default("")                    // 검증 콜백용
  adminNote    String       @default("")                    // admin 검토 메모
  createdAt    DateTime     @default(now())
  reviewedAt   DateTime?

  shop     Shop @relation(fields: [shopId],     references: [id], onDelete: Cascade)
  claimant User @relation("ClaimRequester", fields: [claimantId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])     // admin 검토 큐
  @@index([shopId])                // 같은 업소 중복 신청 체크
  @@index([claimantId, createdAt]) // 사용자가 신청한 클레임 내역
}

// ── SiteConfig — 사이트 전역 토글 (singleton, id=1 고정) ────────────────────

model SiteConfig {
  id                     Int        @id @default(1)        // 항상 1
  isShopCommunityActive  Boolean    @default(false)        // 업소 전용 비밀 게시판 ON/OFF
  mainLayout             MainLayout @default(GRID)         // 메인 페이지 레이아웃 종류
  updatedAt              DateTime   @updatedAt
}

// ── BoardPost — 일반 게시판 (category 로 다중 게시판 분기, polymorphic) ────
//   category 예시: 'shop_only', 'free', 'notice', ...
//   업소 전용은 'shop_only' 로 저장하고 페이지에서 필터.

model BoardPost {
  id        Int      @id @default(autoincrement())
  category  String   @db.VarChar(32)
  title     String
  content   String   @db.Text
  authorId  Int
  isVisible Boolean  @default(true)
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  author User @relation("BoardPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([category, createdAt])     // 게시판별 최신순 (핵심)
  @@index([authorId, createdAt])     // 작성자별
  @@index([category, isVisible, deletedAt])
}
