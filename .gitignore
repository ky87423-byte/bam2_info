# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# 런타임 로컬 데이터 (비밀번호 해시·개인정보 포함 가능)
/data/
/dev.log
/.claude/
/prisma/migrations/**/*.sql.snapshot

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# scraper (bam2_info/scraper/)
/scraper/node_modules/
/scraper/scraped_data/*.log
/scraper/scraped_data/shops.json.bak.*
/scraper/scraped_data/urls.json.bak.*
/scraper/scraped_data/webp-convert-failures.txt

# 일회성 작업 로그
/scripts/*.log

# DB 백업 (개인정보 포함)
/backups/

# 스크래퍼가 다운로드하는 이미지 (84GB 규모 — git 추적 부적합)
# 빌드 환경에서는 별도 백업/동기화 필요 (예: rsync, S3)
/public/images/imgs/
